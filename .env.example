# Copy to .env and adjust. Used by docker-compose.

# --- Host port mappings ---
BACKEND_PORT=8000
FRONTEND_PORT=5173
ADMIN_PORT=5174
MONGO_PORT=27017
REDIS_PORT=6379

# --- Database ---
MONGO_DB=payroll

# --- Public URLs (used for CORS + links + stored upload/logo URLs) ---
# IMPORTANT: the protocol/host here is baked into stored file URLs (e.g. company
# logos -> {APP_BASE_URL}/uploads/...). It MUST match how browsers actually reach
# the backend. Deploying on a bare IP without TLS? Use http:// everywhere — the
# backend serves plain HTTP on port 8000, so an https:// value here makes images
# fail to load. Only use https:// once the backend sits behind a TLS proxy.
#
# Example for a VPS at 157.245.133.12 (no TLS):
#   APP_BASE_URL=http://157.245.133.12:8000
#   CLIENT_BASE_URL=http://157.245.133.12:5173
#   ADMIN_BASE_URL=http://157.245.133.12:5174
#   VITE_API_URL=http://157.245.133.12:8000/api/v1
APP_BASE_URL=http://localhost:8000
CLIENT_BASE_URL=http://localhost:5173
ADMIN_BASE_URL=http://localhost:5174

# Baked into the frontend/admin bundles at build time.
VITE_API_URL=http://localhost:8000/api/v1

# --- Auth (REQUIRED, min 16 chars for access secret) ---
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

COOKIE_SECRET=change-me-cookie-secret

# --- Email (Brevo, REQUIRED) ---
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=no-reply@example.com
BREVO_SENDER_NAME=PM-Safu
# Optional. Public URL of the logo shown in emails. Leave blank to use the
# logo bundled with the backend at {APP_BASE_URL}/assets/logo.png.
EMAIL_LOGO_URL=

# --- Groq AI (optional) ---
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
GROQ_MODEL_FAST=openai/gpt-oss-20b

# --- Super admin seed (optional) ---
SUPERADMIN_SEED_EMAIL=
SUPERADMIN_SEED_PASSWORD=

# --- Payroll ---
PAYROLL_SYNC_THRESHOLD=50
