# Copy to .env and adjust. Used by docker-compose.

# --- Host port mappings ---
BACKEND_PORT=8000
FRONTEND_PORT=5173
ADMIN_PORT=5174
MONGO_PORT=27017
REDIS_PORT=6379

# --- Database ---
MONGO_DB=payroll

# --- Public URLs (used for CORS + links) ---
APP_BASE_URL=http://localhost:8000
CLIENT_BASE_URL=http://localhost:5173
ADMIN_BASE_URL=http://localhost:5174

# Baked into the frontend/admin bundles at build time.
VITE_API_URL=http://localhost:8000/api/v1

# --- Auth (REQUIRED, min 16 chars for access secret) ---
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

COOKIE_SECRET=change-me-cookie-secret

# --- Email (Brevo, REQUIRED) ---
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=no-reply@example.com
BREVO_SENDER_NAME=PM-Safu

# --- Groq AI (optional) ---
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
GROQ_MODEL_FAST=openai/gpt-oss-20b

# --- Super admin seed (optional) ---
SUPERADMIN_SEED_EMAIL=
SUPERADMIN_SEED_PASSWORD=

# --- Payroll ---
PAYROLL_SYNC_THRESHOLD=50
