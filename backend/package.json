{
  "name": "invoice-payroll-platform-backend",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch --env-file=.env src/index.ts",
    "start": "NODE_ENV=production bun src/index.ts",
    "dev:worker": "bun --watch --env-file=.env src/workers/index.ts",
    "start:worker": "NODE_ENV=production bun src/workers/index.ts",
    "seed:superadmin": "bun --env-file=.env src/scripts/seedSuperAdmin.ts",
    "seed:demo": "bun --env-file=.env src/scripts/seedDemo.ts",
    "seed:demo:reset": "DEMO_RESET=true bun --env-file=.env src/scripts/seedDemo.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/bun": "^1.3.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/pdfkit": "^0.13.9",
    "@types/swagger-ui-express": "^4.1.8"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.58.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^7.4.1",
    "fuse.js": "^7.4.2",
    "groq-sdk": "^1.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.7.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.18.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "pdfkit": "^0.15.1",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^4.2.0",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.23.8"
  }
